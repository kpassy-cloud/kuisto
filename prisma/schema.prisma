generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  directUrl         = env("DIRECT_DATABASE_URL")
  relationMode      = "prisma"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String           @id @default(cuid())
  email         String           @unique
  emailVerified DateTime?
  name          String?
  image         String?
  password      String?
  role          String           @default("user")
  country       String?
  region        String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  accounts      Account[]
  adImpressions AdImpression[]
  favorites     Favorite[]
  mealPlans     MealPlan[]
  history       RecipeHistory[]
  sessions      Session[]
  subscription  Subscription?
  bonuses       UserBonus[]
  preferences   UserPreferences?
}

model UserPreferences {
  id               String   @id @default(cuid())
  userId           String   @unique
  vegetarian       Boolean  @default(false)
  vegan            Boolean  @default(false)
  glutenFree       Boolean  @default(false)
  lactoseFree      Boolean  @default(false)
  keto             Boolean  @default(false)
  halal            Boolean  @default(false)
  kosher           Boolean  @default(false)
  nutAllergy       Boolean  @default(false)
  peanutAllergy    Boolean  @default(false)
  shellfishAllergy Boolean  @default(false)
  eggAllergy       Boolean  @default(false)
  soyAllergy       Boolean  @default(false)
  fishAllergy      Boolean  @default(false)
  servingSize      Int      @default(2)
  difficultyLevel  String   @default("easy")
  maxPrepTime      Int      @default(30)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  recipeName String
  recipeData String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, recipeName])
}

model RecipeHistory {
  id          String   @id @default(cuid())
  userId      String
  recipeName  String
  recipeData  String
  ingredients String
  rating      Int?
  cookedAt    DateTime @default(now())
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MealPlan {
  id         String   @id @default(cuid())
  userId     String
  date       String
  mealType   String
  recipeName String
  recipeData String
  completed  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, mealType])
}

model ShoppingList {
  id          String   @id @default(cuid())
  userId      String
  ingredient  String
  quantity    String
  unit        String?
  isChecked   Boolean  @default(false)
  recipeNames String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  plan                 String    @default("free")
  status               String    @default("active")
  stripeCustomerId     String?
  stripeSubscriptionId String?
  stripePriceId        String?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  recipesGenerated     Int       @default(0)
  mealPlansCreated     Int       @default(0)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserBonus {
  id        String    @id @default(cuid())
  userId    String
  type      String
  value     Int
  reason    String?
  expiresAt DateTime?
  used      Boolean   @default(false)
  grantedBy String?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Ad {
  id              String    @id @default(cuid())
  title           String
  description     String?
  imageUrl        String?
  linkUrl         String?
  buttonText      String?
  type            String    @default("banner")
  targetTiers     String    @default("free")
  targetCountries String?
  targetRegions   String?
  active          Boolean   @default(true)
  startDate       DateTime?
  endDate         DateTime?
  priority        Int       @default(0)
  impressions     Int       @default(0)
  clicks          Int       @default(0)
  createdBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([active, type])
  @@index([startDate, endDate])
}

model AdImpression {
  id       String   @id @default(cuid())
  adId     String
  userId   String
  viewed   Boolean  @default(true)
  clicked  Boolean  @default(false)
  viewedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([adId, userId])
  @@index([userId, viewedAt])
}

model NewsFeed {
  id              String    @id @default(cuid())
  title           String
  content         String
  imageUrl        String?
  linkUrl         String?
  category        String    @default("tip")
  targetTiers     String    @default("all")
  targetCountries String?
  active          Boolean   @default(true)
  publishAt       DateTime  @default(now())
  expiresAt       DateTime?
  featured        Boolean   @default(false)
  sticky          Boolean   @default(false)
  views           Int       @default(0)
  likes           Int       @default(0)
  authorId        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([active, publishAt])
  @@index([featured, sticky])
}

model Announcement {
  id              String    @id @default(cuid())
  title           String
  message         String
  type            String    @default("info")
  icon            String?
  targetUsers     String    @default("all")
  targetCountries String?
  displayType     String    @default("banner")
  dismissible     Boolean   @default(true)
  active          Boolean   @default(true)
  startDate       DateTime?
  endDate         DateTime?
  views           Int       @default(0)
  dismissals      Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([active, startDate, endDate])
}

model Analytics {
  id                    String   @id @default(cuid())
  date                  String   @unique
  newUsers              Int      @default(0)
  activeUsers           Int      @default(0)
  newSubscriptions      Int      @default(0)
  canceledSubscriptions Int      @default(0)
  premiumUsers          Int      @default(0)
  proUsers              Int      @default(0)
  freeUsers             Int      @default(0)
  revenue               Float    @default(0)
  recipesGenerated      Int      @default(0)
  avgRecipesPerUser     Float    @default(0)
  adImpressions         Int      @default(0)
  adClicks              Int      @default(0)
  adRevenue             Float    @default(0)
  feedViews             Int      @default(0)
  feedEngagement        Float    @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model AdminLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  targetType String
  targetId   String?
  details    String?
  createdAt  DateTime @default(now())

  @@index([adminId])
  @@index([targetType, targetId])
}

model AdminKey {
  id          String    @id @default(cuid())
  key         String    @unique
  name        String?
  description String?
  usedBy      String?
  usedAt      DateTime?
  maxUses     Int       @default(1)
  useCount    Int       @default(0)
  active      Boolean   @default(true)
  expiresAt   DateTime?
  createdBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([key])
  @@index([active])
}
