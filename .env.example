# Database (PostgreSQL - required for Vercel production)
# Vercel Postgres auto-populates these when you connect the database:
# - POSTGRES_URL (pooled connection for serverless)
# - POSTGRES_URL_NON_POOLING (direct connection for migrations)
# - POSTGRES_USER, POSTGRES_HOST, POSTGRES_PASSWORD, POSTGRES_DATABASE
POSTGRES_URL="postgresql://user:password@host:5432/database?pgbouncer=true&connect_timeout=15"
POSTGRES_URL_NON_POOLING="postgresql://user:password@host:5432/database?connect_timeout=15"

# For local development with Neon or other PostgreSQL providers:
# DATABASE_URL="postgresql://user:password@host:5432/database?pgbouncer=true&connect_timeout=15"
# DIRECT_DATABASE_URL="postgresql://user:password@host:5432/database?connect_timeout=15"

# NextAuth.js
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="https://kuisto.ca"

# AI Services (for recipe generation)
Z_AI_API_KEY="your-z-ai-api-key"

# Optional: Stripe for payments
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Optional: Email service
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASSWORD=""
